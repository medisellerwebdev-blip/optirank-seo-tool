{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "destination": "https://[YOUR-CLOUD-RUN-URL]/api/**"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
